MainSection:AddToggle({
    Name = "Auto Pet Battle(Bật Auto Catch)",
    Default = false,
    Callback = function(value)
        getgenv().AutoPetBattle = value
        if not value then return end

        task.spawn(function()
            local Players = game:GetService("Players")
            local player = Players.LocalPlayer
            local VirtualInputManager = game:GetService("VirtualInputManager")

            local cache = workspace:WaitForChild("RuntimeCache")
                :WaitForChild("RuntimeCacheServer")
                :WaitForChild("CreatureModelCache")

            local function hasPetChild(obj)
                for _, child in ipairs(obj:GetChildren()) do
                    if string.find(child.Name, "Pet0_") then
                        return true
                    end
                end
                return false
            end

            local function FindAndEnterBattle()
                if not getgenv().AutoPetBattle then return nil end

                local character = player.Character or player.CharacterAdded:Wait()
                local rootPart = character:WaitForChild("HumanoidRootPart")

                local foundId = nil
                for _, obj in ipairs(cache:GetChildren()) do
                    if hasPetChild(obj) then
                        local objPosition
                        if obj:IsA("Model") then
                            objPosition = obj:GetPivot().Position
                        elseif obj:IsA("BasePart") then
                            objPosition = obj.Position
                        end

                        if objPosition then
                            local distance = (objPosition - rootPart.Position).Magnitude
                            if distance <= 50 then
                                foundId = obj.Name
                                break
                            end
                        end
                    end
                end

                if foundId then
                    game:GetService("ReplicatedStorage"):WaitForChild("Remote"):WaitForChild("Battle"):WaitForChild("ReqEnterPetBattle"):FireServer(foundId)
                end

                return foundId
            end

            local autoCatchText = player.PlayerGui
                :WaitForChild("UIPrefabs")
                :WaitForChild("BattleCatchPetWindow")
                :WaitForChild("MainCanvasGroup")
                :WaitForChild("BallFrame")
                :WaitForChild("AutoCatchFrame")
                :WaitForChild("AutoTimeText")

            autoCatchText:GetPropertyChangedSignal("Text"):Connect(function()
                if not getgenv().AutoPetBattle then return end
                local text = autoCatchText.Text
                if text == "(3s)" or text == "(2s)" or text == "(1s)" then
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.C, false, game)
                    task.wait(0.1)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.C, false, game)
                    task.wait(1.5)
                    FindAndEnterBattle()
                end
            end)

            while getgenv().AutoPetBattle do
                local foundId = FindAndEnterBattle()

                if not foundId then
                    task.wait(1.5)
                    continue
                end

                local countdownText = player.PlayerGui
                    :WaitForChild("UIPrefabs")
                    :WaitForChild("MainBattleWindow")
                    :WaitForChild("MainCanvasGroup")
                    :WaitForChild("TopFrame")
                    :WaitForChild("CountdownFrame")
                    :WaitForChild("CountdownText")

                repeat task.wait(0.1) until not getgenv().AutoPetBattle
                    or (tonumber(countdownText.Text) and tonumber(countdownText.Text) <= 29)

                if not getgenv().AutoPetBattle then break end

                local countdownActive = true
                local conn = countdownText:GetPropertyChangedSignal("Text"):Connect(function()
                    if not tonumber(countdownText.Text) then
                        countdownActive = false
                    end
                end)

                while countdownActive and getgenv().AutoPetBattle do
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                    task.wait(math.random(30, 80) / 100)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                end
                conn:Disconnect()

                task.wait(1)
            end
        end)
    end
})

Settings:AddToggle({
    Name = "Chest ESP",
    Default = false,
    Callback = function(value)
        if value then
            local Players = game:GetService("Players")
            local RunService = game:GetService("RunService")
            local player = Players.LocalPlayer
            local camera = workspace.CurrentCamera

            local chestFolder = workspace:WaitForChild("RuntimeCache")
                :WaitForChild("RuntimeCacheClient")
                :WaitForChild("Chest")

            getgenv().ChestESPObjects = {}

            local function getChestPrimaryPart(obj)
                for _, child in ipairs(obj:GetChildren()) do
                    if child.Name:match("^Chest") then
                        if child:IsA("BasePart") then
                            return child
                        end
                        if child:IsA("Model") then
                            return child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")
                        end
                    end
                end
                return obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
            end

            local function createESP(obj)
                local billboard = Instance.new("BillboardGui")
                billboard.Name = "ChestESP"
                billboard.AlwaysOnTop = true
                billboard.Size = UDim2.new(0, 150, 0, 40)
                billboard.StudsOffset = Vector3.new(0, 3, 0)

                local label = Instance.new("TextLabel")
                label.Size = UDim2.new(1, 0, 1, 0)
                label.BackgroundTransparency = 1
                label.TextColor3 = Color3.fromRGB(255, 200, 0)
                label.TextStrokeTransparency = 0
                label.TextScaled = true
                label.Font = Enum.Font.GothamBold
                label.Parent = billboard

                local part = getChestPrimaryPart(obj)
                if part then
                    billboard.Adornee = part
                    billboard.Parent = part
                end

                getgenv().ChestESPObjects[obj] = { billboard = billboard, label = label }
            end

            local function removeESP(obj)
                if getgenv().ChestESPObjects[obj] then
                    getgenv().ChestESPObjects[obj].billboard:Destroy()
                    getgenv().ChestESPObjects[obj] = nil
                end
            end

            for _, obj in ipairs(chestFolder:GetChildren()) do
                createESP(obj)
            end

            getgenv().ChestESPChildAdded = chestFolder.ChildAdded:Connect(function(obj)
                createESP(obj)
            end)

            getgenv().ChestESPChildRemoved = chestFolder.ChildRemoved:Connect(function(obj)
                removeESP(obj)
            end)

            getgenv().ChestESPRender = RunService.RenderStepped:Connect(function()
                local character = player.Character
                local hrp = character and character:FindFirstChild("HumanoidRootPart")
                if not hrp then return end

                for obj, data in pairs(getgenv().ChestESPObjects) do
                    if not obj.Parent then
                        removeESP(obj)
                        continue
                    end

                    local part = getChestPrimaryPart(obj)
                    if part then
                        local distance = (hrp.Position - part.Position).Magnitude
                        data.label.Text = string.format("Chest\n%.1f studs", distance)
                    end
                end
            end)

        else
            -- Dọn dẹp khi tắt toggle
            if getgenv().ChestESPRender then
                getgenv().ChestESPRender:Disconnect()
            end
            if getgenv().ChestESPChildAdded then
                getgenv().ChestESPChildAdded:Disconnect()
            end
            if getgenv().ChestESPChildRemoved then
                getgenv().ChestESPChildRemoved:Disconnect()
            end
            if getgenv().ChestESPObjects then
                for _, data in pairs(getgenv().ChestESPObjects) do
                    data.billboard:Destroy()
                end
                getgenv().ChestESPObjects = {}
            end
        end
    end
})

local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local PLACE_ID = game.PlaceId
local currentJobId = game.JobId

local function GetServers(cursor)
    local url = "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?limit=100&sortOrder=Asc"
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. cursor
    end
    local ok, result = pcall(function()
        return request({ Url = url, Method = "GET" })
    end)
    if not ok or not result or not result.Body then return nil end
    local ok2, data = pcall(function()
        return HttpService:JSONDecode(result.Body)
    end)
    if not ok2 or not data then return nil end
    return data
end

MiscSection:AddButton({
    Name = "Hop Server",
    Callback = function()
        local allCandidates = {}
        local cursor = ""

        repeat
            local data = GetServers(cursor)
            if not data or not data.data then break end

            for _, server in ipairs(data.data) do
                if server.id ~= currentJobId
                    and type(server.playing) == "number"
                    and type(server.maxPlayers) == "number"
                    and server.playing <= server.maxPlayers - 2
                    and server.playing > 0 then
                    table.insert(allCandidates, server)
                end
            end

            cursor = data.nextPageCursor
        until not cursor or cursor == ""

        if #allCandidates > 0 then
            for i = #allCandidates, 2, -1 do
                local j = math.random(1, i)
                allCandidates[i], allCandidates[j] = allCandidates[j], allCandidates[i]
            end
            local chosen = allCandidates[1]
            TeleportService:TeleportToPlaceInstance(PLACE_ID, chosen.id, Players.LocalPlayer)
        else
            TeleportService:Teleport(PLACE_ID, Players.LocalPlayer)
        end
    end
})

