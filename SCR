local BossList = {
    ["15"]  = {10002, 9000002},
    ["30"]  = {10004, 9000003},
    ["60"]  = {10008, 9000005},
    ["751"] = {10020, 9000014},
    ["752"] = {10009, 9000006},
    ["90"]  = {10011, 9000007},
    ["105"] = {10012, 9000008},
    ["120"] = {10014, 9000009},
    ["135"] = {10016, 9000010},
    ["150"] = {10017, 9000011},
    ["165"] = {10019, 9000012},
    ["175"] = {10021, 9000013},
}

getgenv().MonsId = "1e27039e-2e4e-4d74-b64f-9662ae7d26c6"
getgenv().BossLevel = "30"
getgenv().LoopInterval = 5   -- khoảng chờ TRƯỚC KHI tìm trận mới (giữa các lượt)
getgenv().AutoNpcBattle = false

local WATCHDOG_TIMEOUT = 20  -- thời gian cố định để phát hiện trận bị treo, KHÔNG liên quan LoopInterval


Boss:AddTextbox({
    Name = "Mons ID (UUID)",
    Default = getgenv().MonsId,
    Callback = function(value)
        if value and value ~= "" then
            getgenv().MonsId = value
        end
    end
})

Boss:AddTextbox({
    Name = "Boss Lvl (vd: 751, 752)",
    Default = getgenv().BossLevel,
    Callback = function(value)
        if BossList[value] then
            getgenv().BossLevel = value
        end
    end
})

Boss:AddTextbox({
    Name = "Thời gian chờ giữa các lượt tìm trận (giây)",
    Default = tostring(getgenv().LoopInterval),
    Callback = function(value)
        local n = tonumber(value)
        if n and n > 0 then
            getgenv().LoopInterval = n
        end
    end
})


Boss:AddToggle({
    Name = "Auto Boss",
    Default = false,
    Callback = function(value)
        getgenv().AutoNpcBattle = value
        if not value then return end

        task.spawn(function()
            local Players = game:GetService("Players")
            local player = Players.LocalPlayer
            local VirtualInputManager = game:GetService("VirtualInputManager")

            local Event = game:GetService("ReplicatedStorage")
                :WaitForChild("Remote")
                :WaitForChild("Battle")
                :WaitForChild("ReqEnterNpcBattle")

            local function FindAndEnterBattle()
                if not getgenv().AutoNpcBattle then return nil end

                local boss = BossList[getgenv().BossLevel]
                if not boss or getgenv().MonsId == "" then
                    return nil
                end

                local ok, err = pcall(function()
                    Event:FireServer(boss[1], boss[2], getgenv().MonsId)
                end)

                if not ok then
                    warn("FireServer lỗi: " .. tostring(err))
                    return nil
                end

                task.wait(4)
                return true
            end

            local catchCompleted = false
            local lastKeyActionTime = tick()

            local autoCatchText = player.PlayerGui
                :WaitForChild("UIPrefabs")
                :WaitForChild("BattleCatchPetWindow")
                :WaitForChild("MainCanvasGroup")
                :WaitForChild("BallFrame")
                :WaitForChild("AutoCatchFrame")
                :WaitForChild("AutoTimeText")

            autoCatchText:GetPropertyChangedSignal("Text"):Connect(function()
                if not getgenv().AutoNpcBattle then return end
                local text = autoCatchText.Text

                if getgenv().Catch then
                    if text == "(3s)" or text == "(2s)" or text == "(1s)" then
                        task.spawn(function()
                            while getgenv().AutoNpcBattle and getgenv().Catch do
                                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                                task.wait(0.5)
                                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                                lastKeyActionTime = tick()
                                task.wait(6)

                                local currentText = autoCatchText.Text
                                if currentText ~= "(3s)" and currentText ~= "(2s)" and currentText ~= "(1s)" then
                                    task.wait(2)
                                    catchCompleted = true
                                    break
                                end
                            end
                        end)
                    end
                else
                    if text == "(3s)" or text == "(2s)" or text == "(1s)" then
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.C, false, game)
                        task.wait(0.5)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.C, false, game)
                        lastKeyActionTime = tick()
                        task.wait(2)
                        catchCompleted = true
                    end
                end
            end)

            while getgenv().AutoNpcBattle do
                local entered = FindAndEnterBattle()

                if not entered then
                    -- Không vào được trận (thiếu thông tin / lỗi) -> chờ LoopInterval rồi thử lại
                    task.wait(getgenv().LoopInterval)
                    continue
                end

                catchCompleted = false
                lastKeyActionTime = tick()

                local countdownText = player.PlayerGui
                    :WaitForChild("UIPrefabs")
                    :WaitForChild("MainBattleWindow")
                    :WaitForChild("MainCanvasGroup")
                    :WaitForChild("TopFrame")
                    :WaitForChild("CountdownFrame")
                    :WaitForChild("CountdownText")

                repeat task.wait(0.5) until not getgenv().AutoNpcBattle
                    or catchCompleted
                    or (tonumber(countdownText.Text) and tonumber(countdownText.Text) <= 29)

                if not getgenv().AutoNpcBattle then break end

                if catchCompleted then
                    -- Trận kết thúc sớm (bắt xong ngay) -> chờ LoopInterval rồi tìm trận mới
                    task.wait(getgenv().LoopInterval)
                    continue
                end

                while getgenv().AutoNpcBattle and not catchCompleted do
                    local num = tonumber(countdownText.Text)

                    if num then
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                        task.wait(math.random(100, 130) / 100)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                    else
                        task.wait(1)
                        num = tonumber(countdownText.Text)
                        if num then
                            -- vẫn đang đếm, tiếp tục
                        else
                            break
                        end
                    end

                    -- Watchdog CỐ ĐỊNH: phát hiện trận bị treo (không liên quan LoopInterval)
                    if tick() - lastKeyActionTime >= WATCHDOG_TIMEOUT then
                        warn("Watchdog: " .. WATCHDOG_TIMEOUT .. "s không phát hiện E/C, thoát trận")
                        break
                    end
                end

                -- Kết thúc lượt (dù bình thường hay do watchdog) -> luôn chờ LoopInterval trước khi tìm trận mới
                task.wait(getgenv().LoopInterval)
            end
        end)
    end
})
